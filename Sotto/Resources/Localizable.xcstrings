  "strings" : {
    "%@ - %@" : {
      "comment" : "A button label that shows the name of a hotkey, followed by a message that instructs the user to tap again to confirm a double-tap. The argument is the value of the localized string key “tap again for double-tap…”.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ - %2$@"
          }
        }
      }
    },
    "%lld%%" : {
      "comment" : "A label showing the percentage of a download. The value is a percentage between 0 and 1.",
      "isCommentAutoGenerated" : true
    },
    "About" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
